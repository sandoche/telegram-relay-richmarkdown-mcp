# Required: Telegram bot token issued by @BotFather.
TELEGRAM_BOT_TOKEN=

# Required: fixed Telegram destination.
# Private user chat: positive ID, e.g. 123456789
# Basic group: negative ID, e.g. -123456789
# Supergroup/channel: normally -100..., e.g. -1001234567890
TELEGRAM_CHANNEL_ID=

# Required: URL-safe random secret, at least 32 characters.
# Generate with: openssl rand -hex 32
MCP_ACCESS_TOKEN=

# Optional. Defaults to true.
TELEGRAM_PROTECT_CONTENT=true

# Optional. Defaults to false.
TELEGRAM_SKIP_ENTITY_DETECTION=false

# Optional best-effort per-instance limit. Defaults to 5, range 1..30.
MCP_MAX_MESSAGES_PER_MINUTE=5

# Optional duplicate suppression window. Defaults to 120 seconds, range 0..600.
MCP_DUPLICATE_WINDOW_SECONDS=120
